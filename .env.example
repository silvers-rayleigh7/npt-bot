# --- Telegram ---
TELEGRAM_BOT_TOKEN=          # от @BotFather
TELEGRAM_CHAT_ID=            # твой numeric Telegram ID (getUpdates)

# --- STT (распознавание речи) ---
GROQ_API_KEY=               # console.groq.com (free-tier)

# --- TTS (озвучка) ---
ELEVENLABS_API_KEY=         # elevenlabs.io
ELEVENLABS_VOICE_ID=        # id выбранного голоса «Профессор»

# --- Claude Code (OAuth-подписка, НЕ API-биллинг) ---
CLAUDE_CODE_OAUTH_TOKEN=    # claude setup-token (на машине с браузером, под Max/Pro)

# --- Конфиг бота ---
CLAUDE_WORK_DIR=/root/tropa-bot
CLAUDE_TG_MODEL=claude-haiku-4-5-20251001
CLAUDE_TG_SESSION_TIMEOUT=3600     # сброс памяти диалога после N сек молчания (1 ч)
CLAUDE_TG_MAX_USERS=8              # лимит авто-регистрации аккаунтов по /start (0 = без лимита)
