# site-bar бэкенд — переменные окружения (реальный .env в .gitignore, в git НЕ коммитим)

# GigaChat (основной провайдер)
GIGACHAT_AUTH_KEY=<base64 client_id:client_secret из письма Сбера>
GIGACHAT_SCOPE=GIGACHAT_API_CORP
GIGACHAT_MODEL=GigaChat-2-Max
# GIGACHAT_CA=/etc/ssl/certs/russian_trusted_root_ca.pem   # путь к RU CA (иначе verify off)

# OpenRouter / DeepSeek (fallback)
OPENROUTER_API_KEY=<ключ OpenRouter>
OPENROUTER_MODEL=deepseek/deepseek-chat

# Поведение
MAX_TOKENS=700
TEMPERATURE=0.4
CORS_ORIGINS=https://tropa.fmin.xyz
