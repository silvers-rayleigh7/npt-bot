#import "/content/figures/_preamble.typ": *
#set page(width: auto, height: auto, margin: 8pt, fill: white)
#set text(font: "Libertinus Serif", size: 11pt, fill: INK)

// Схема-карта двух петель тропы. Абстрактная (НЕ спутник/ландшафт):
// из одной точки входа выходят две замкнутые петли-маршрута — короткая ~4 км
// (внутренняя, олива) и длинная ~12 км (внешняя, охватывает короткую, чернила).
// Вдоль маршрутов — равномерные точки-станции. У входа — пин «вы здесь».
#cetz.canvas(length: 1cm, {
  import cetz.draw: *
  set-style(stroke: (paint: INK, thickness: LINE))

  // ── общая точка входа (низ, по центру обеих петель)
  let ex = 4.6
  let ey = 0.0

  // ── ДЛИННАЯ петля ~12 км: крупный гладкий замкнутый контур, проходит через вход.
  //    Силуэт живой-неправильный (не овал): где-то выгиб шире, где-то уже — как
  //    настоящий маршрут по местности. Опоры идут по часовой от входа.
  let longpts = (
    (ex, ey),            // вход (низ)
    (1.9, 0.9),
    (0.6, 3.1),
    (1.5, 5.4),
    (4.0, 6.9),
    (6.8, 6.4),
    (8.7, 4.2),
    (8.0, 1.7),
  )
  hobby(..longpts, close: true,
        stroke: (paint: INK, thickness: 1.6pt))

  // ── КОРОТКАЯ петля ~4 км: маленький «лепесток» из того же входа, ЦЕЛИКОМ
  //    ВНУТРИ длинной. Периметр примерно втрое меньше — это сразу читается глазом:
  //    «эта втрое короче». Не пересекает чёрный контур, не уходит за него.
  let shortpts = (
    (ex, ey),            // тот же вход (низ)
    (5.7, 1.2),
    (5.5, 2.9),
    (4.6, 3.5),
    (3.7, 2.9),
    (3.5, 1.2),
  )
  hobby(..shortpts, close: true,
        stroke: (paint: OLIVE, thickness: 1.5pt))

  // ── маркер «вы здесь»: пин Lucide над точкой входа + подписи
  content((ex, ey - 0.02), anchor: "south", image("icons/map-pin.svg", width: 0.7cm))
  // узловой кружок самого входа (общая стартовая точка обеих петель)
  circle((ex, ey), radius: 0.10, fill: INK, stroke: none)
  content((ex, ey - 0.40), text(size: 11pt)[вход])
  content((ex, ey - 0.92), text(size: 9pt, fill: OLIVE)[вы здесь])

  // ── подписи длины: «4 км» в чистом центре короткой петли, «12 км» в верхней
  //    зоне длинной (выше короткой, не задевая линий), цвет = цвету своей петли.
  content((4.6, 2.15), text(size: 11pt, fill: OLIVE)[4 км])
  content((4.5, 5.4), text(size: 11pt, fill: INK)[12 км])
})
