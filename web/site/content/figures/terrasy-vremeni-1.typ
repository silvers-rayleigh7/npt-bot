#import "/content/figures/_preamble.typ": *
#set page(width: auto, height: auto, margin: 8pt, fill: white)
#set text(font: "Libertinus Serif", size: 11pt, fill: INK)

// Поперечный профиль речной долины как ЛЕСТНИЦА. Абстрактная диаграмма (НЕ ландшафт):
// ломаная-профиль — внизу узкое современное русло, выше 2–3 плоские площадки-террасы,
// между ними короткие крутые уступы. База падала рывками → пунктирные горизонтали
// (прежние уровни реки) на каждой ступени. Слева — стрелка-высота H от русла до
// верхней террасы. Подписи: русло · терраса · уступ. Свет/верх — сверху.
#cetz.canvas(length: 1cm, {
  import cetz.draw: *
  set-style(stroke: (paint: INK, thickness: LINE), mark: (fill: INK, scale: 0.6))

  // ── узлы профиля слева→направо: дно русла, борт русла, затем лестница вверх.
  //    Плоские террасы (горизонтальные участки) разделены короткими крутыми уступами.
  let chBot  = (1.30, 0.00)   // дно современного русла
  let chTop  = (1.85, 0.55)   // бровка русла (низ первой террасы)
  let t1a    = (1.85, 0.55)   // терраса 1 — низкая пойменная площадка
  let t1b    = (4.30, 0.55)
  let r1      = (4.85, 1.55)   // уступ 1 (крутой)
  let t2a    = (4.85, 1.55)   // терраса 2 — средняя
  let t2b    = (7.00, 1.55)
  let r2      = (7.55, 2.65)   // уступ 2 (крутой)
  let t3a    = (7.55, 2.65)   // терраса 3 — верхняя (коренной берег)
  let t3b    = (9.70, 2.65)

  // зеркальный левый борт русла — чтобы «русло» читалось как узкая V-врезка
  let chTopL = (0.75, 0.55)

  // ── ЛИНИЯ-ПРОФИЛЬ: левый борт — дно русла — правый борт — лестница террас.
  line(
    chTopL, chBot, chTop, t1b, r1, t2b, r2, t3b,
    stroke: (paint: INK, thickness: 1.6pt),
  )

  // ── штриховка «грунта» под профилем террас — короткие косые штрихи, приглушённо,
  //    намёк на тело отложений под площадками (как грунт в geo/uslysh, без заливки).
  let hatchFlat(x0, x1, y) = {
    let n = int((x1 - x0) / 0.34)
    for i in range(0, n + 1) {
      let hx = x0 + i * 0.34
      line((hx, y), (hx - 0.18, y - 0.24), stroke: (paint: SAND, thickness: 0.5pt))
    }
  }
  hatchFlat(1.0, 4.30, 0.55)
  hatchFlat(4.85, 7.00, 1.55)
  hatchFlat(7.55, 9.60, 2.65)

  // ── ПУНКТИРНЫЕ ГОРИЗОНТАЛИ — прежние уровни реки (база падала рывками).
  //    Каждая на высоте своей террасы, тянется влево над руслом: «когда-то река
  //    текла здесь». Аккуратный мелкий пунктир, олива.
  let oldLevel(y, x1) = {
    line((0.55, y), (x1, y),
      stroke: (paint: OLIVE, thickness: 0.7pt, dash: (array: (2pt, 2pt))))
  }
  oldLevel(1.55, 4.85)   // уровень террасы 2
  oldLevel(2.65, 7.55)   // уровень террасы 3 (самый древний)

  // ── СТРЕЛКА-ВЫСОТА H: от уровня русла до верхней террасы, слева, двунаправленная.
  let hx = 0.20
  line((hx, 0.00), (hx, 2.65), mark: (start: ">", end: ">"),
       stroke: (paint: INK, thickness: 0.9pt))
  // тонкие выноски к концам стрелки (уровень русла ↔ верхняя терраса)
  line((hx, 0.00), (1.20, 0.00), stroke: (paint: INK, thickness: 0.45pt))
  line((hx, 2.65), (0.55, 2.65), stroke: (paint: INK, thickness: 0.45pt))
  content((hx - 0.34, 1.32), anchor: "east", text(size: 11pt)[$H$])

  // ── ПОДПИСИ ────────────────────────────────────────────────────────────────
  // русло — под бровкой, у дна врезки
  content((1.30, -0.46), text(size: 10pt)[русло])

  // террасы — по центру каждой плоской площадки, с воздухом над поверхностью
  content((3.05, 0.86), text(size: 10pt, fill: OLIVE)[терраса])
  content((5.92, 1.86), text(size: 10pt, fill: OLIVE)[терраса])
  content((8.55, 2.96), text(size: 10pt, fill: OLIVE)[терраса])

  // уступ — выноска к КРУТОМУ диагональному участку (середина нижнего уступа),
  //         подпись в чистой зоне справа от уступа, на уровне террасы 1.
  line((4.575, 1.05), (5.60, 0.78), stroke: (paint: INK, thickness: 0.45pt))
  content((5.70, 0.78), anchor: "west", text(size: 9.5pt)[уступ])
})
